    stacks text,
    community_cards text[],
    final_street smallint DEFAULT '0'::smallint NOT NULL,
    third_blind numeric,
    big_blind_ante boolean DEFAULT false NOT NULL,
    pot_type public.pot_type,
    board_texture public.board_texture[] NOT NULL,
    relative_hero_position public.relative_hero_position NOT NULL,
    CONSTRAINT hands_check CHECK ((big_blind >= small_blind)),
    CONSTRAINT hands_final_pot_size_check CHECK (((final_pot_size IS NULL) OR (final_pot_size >= (0)::numeric))),
    CONSTRAINT hands_hero_cards_check CHECK (((hero_cards IS NULL) OR (char_length(hero_cards) = 4))),
    CONSTRAINT hands_num_players_check CHECK (((num_players >= 2) AND (num_players <= 10))),
    CONSTRAINT hands_small_blind_check CHECK ((small_blind > (0)::numeric))
);


ALTER TABLE public.hands OWNER TO postgres;

--
-- Name: TABLE hands; Type: COMMENT; Schema: public; Owner: postgres
--

COMMENT ON TABLE public.hands IS 'Stores overall information for each recorded poker hand.';


--
-- Name: COLUMN hands.user_id; Type: COMMENT; Schema: public; Owner: postgres
--

COMMENT ON COLUMN public.hands.user_id IS 'The user who recorded/played the hand.';


--
-- Name: COLUMN hands.hero_cards; Type: COMMENT; Schema: public; Owner: postgres
--

COMMENT ON COLUMN public.hands.hero_cards IS 'Hero''s hole cards, 4-char format (e.g., AsKh).';


--
-- Name: player_statistics; Type: TABLE; Schema: public; Owner: postgres
--

CREATE TABLE public.player_statistics (
    user_id uuid NOT NULL,
    hands_played integer DEFAULT 0 NOT NULL,
    vpip_opportunities integer DEFAULT 0 NOT NULL,
    vpip_count integer DEFAULT 0 NOT NULL,
    pfr_opportunities integer DEFAULT 0 NOT NULL,
    pfr_count integer DEFAULT 0 NOT NULL,
    three_bet_opportunities integer DEFAULT 0 NOT NULL,
    three_bet_count integer DEFAULT 0 NOT NULL,
    updated_at timestamp with time zone DEFAULT now()
);


ALTER TABLE public.player_statistics OWNER TO postgres;

--
-- Name: showdown_hands; Type: TABLE; Schema: public; Owner: postgres
--

CREATE TABLE public.showdown_hands (
    id bigint NOT NULL,
    hand_id uuid NOT NULL,
    "position" text NOT NULL,
    is_winner boolean DEFAULT false NOT NULL,
    hand_description text,
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    hole_cards text,
    tag smallint
);


ALTER TABLE public.showdown_hands OWNER TO postgres;

--
-- Name: TABLE showdown_hands; Type: COMMENT; Schema: public; Owner: postgres
--

COMMENT ON TABLE public.showdown_hands IS 'Stores player hole cards revealed at showdown for a specific hand.';


--
-- Name: showdown_hands_id_seq; Type: SEQUENCE; Schema: public; Owner: postgres
--

ALTER TABLE public.showdown_hands ALTER COLUMN id ADD GENERATED BY DEFAULT AS IDENTITY (
    SEQUENCE NAME public.showdown_hands_id_seq
    START WITH 1
    INCREMENT BY 1
    NO MINVALUE
    NO MAXVALUE
    CACHE 1
);


--
-- Name: messages; Type: TABLE; Schema: realtime; Owner: supabase_realtime_admin
--

CREATE TABLE realtime.messages (
    topic text NOT NULL,
    extension text NOT NULL,
    payload jsonb,
    event text,
    private boolean DEFAULT false,
    updated_at timestamp without time zone DEFAULT now() NOT NULL,
    inserted_at timestamp without time zone DEFAULT now() NOT NULL,
    id uuid DEFAULT gen_random_uuid() NOT NULL
)
PARTITION BY RANGE (inserted_at);


