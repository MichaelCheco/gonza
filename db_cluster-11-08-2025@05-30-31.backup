--
-- Name: actions Users can manage actions for their own hands; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage actions for their own hands" ON public.actions USING ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = actions.hand_id)))) WITH CHECK ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = actions.hand_id))));


--
-- Name: hand_pots Users can manage pots for their own hands; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage pots for their own hands" ON public.hand_pots USING ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = hand_pots.hand_id)))) WITH CHECK ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = hand_pots.hand_id))));


--
-- Name: showdown_hands Users can manage showdown info for their own hands; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage showdown info for their own hands" ON public.showdown_hands USING ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = showdown_hands.hand_id)))) WITH CHECK ((auth.uid() = ( SELECT hands.user_id
   FROM public.hands
  WHERE (hands.id = showdown_hands.hand_id))));


--
-- Name: hands Users can manage their own hands; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can manage their own hands" ON public.hands USING ((auth.uid() = user_id)) WITH CHECK ((auth.uid() = user_id));


--
-- Name: player_statistics Users can read their own stats; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can read their own stats" ON public.player_statistics FOR SELECT USING ((auth.uid() = user_id));


